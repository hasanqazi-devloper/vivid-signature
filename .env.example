# ─── Vivid Signature Pro — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Stripe publishable key (safe to expose in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create these in your Stripe Dashboard
# Products > Add product > Add pricing for each tier × interval
VITE_STRIPE_STARTER_MONTHLY=price_...
VITE_STRIPE_STARTER_YEARLY=price_...
VITE_STRIPE_PROFESSIONAL_MONTHLY=price_...
VITE_STRIPE_PROFESSIONAL_YEARLY=price_...
VITE_STRIPE_BUSINESS_MONTHLY=price_...
VITE_STRIPE_BUSINESS_YEARLY=price_...
VITE_STRIPE_ENTERPRISE_MONTHLY=price_...
VITE_STRIPE_ENTERPRISE_YEARLY=price_...
